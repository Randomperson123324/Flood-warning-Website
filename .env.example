# ── Supabase ─────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Weather (optional — falls back to Open-Meteo, no key needed, if unset) ──
TMD_API_TOKEN=

# ── Site ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=StreeFlood
# Comma-separated list of allowed signup email domains, e.g. "streetrat.ac.th".
# Leave empty to allow any email domain. Used starting in Phase 2 (auth).
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=

# ── Refresh intervals (ms) — all optional, sane defaults in lib/config.ts ──
# NEXT_PUBLIC_REALTIME_LIMIT=500
# NEXT_PUBLIC_HISTORY_DAYS=7
# NEXT_PUBLIC_WATER_REFRESH_MS=60000
# NEXT_PUBLIC_WEATHER_REFRESH_MS=300000
# NEXT_PUBLIC_TMD_WARNING_REFRESH_MS=600000
# NEXT_PUBLIC_SENSORS_REFRESH_MS=300000
# NEXT_PUBLIC_WEATHER_API_TIMEOUT_MS=15000
# NEXT_PUBLIC_HOURLY_FORECAST_COUNT=24
# NEXT_PUBLIC_DAILY_FORECAST_DAYS=5

# ── Geolocation ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_GPS_MAX_AGE_MS=300000
# NEXT_PUBLIC_GPS_TIMEOUT_MS=10000

# ── Map ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_MAP_DEFAULT_ZOOM=13
# NEXT_PUBLIC_MAP_TILE_URL_LIGHT=
# NEXT_PUBLIC_MAP_TILE_URL_DARK=
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=

# ── AI assistant (Phase 3) ─────────────────────────────────────────────────
# AI_PROVIDER=gemini | lmstudio
AI_PROVIDER=gemini
AI_MODEL=gemini-3.1-flash-lite
AI_MAX_TOOL_CALL_LOOPS=5
GEMINI_API_KEY=
# only used when AI_PROVIDER=lmstudio (fallback when no Gemini key is set)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_MODEL=local-model
# NEXT_PUBLIC_AI_ANALYSIS_INTERVAL_MS=300000

# Web search tool used by the assistant — Tavily (free, 1,000 searches/month,
# no credit card required): https://app.tavily.com. Falls back automatically
# to DuckDuckGo's much weaker instant-answer API if this is left unset.
TAVILY_API_KEY=

# ── Community (Phase 2) — all optional, sane defaults in lib/config.ts ────
# NEXT_PUBLIC_MESSAGE_RATE_LIMIT_SECONDS=3
# NEXT_PUBLIC_WEATHER_VOTE_COOLDOWN_MS=1800000
# NEXT_PUBLIC_MESSAGES_PAGE_SIZE=50
# NEXT_PUBLIC_FLOOD_REPORT_SUCCESS_MS=3000
# NEXT_PUBLIC_CHAT_NOTICE_MS=2500

# ── Search (used by AI assistant's search_web tool) ───────────────────────
# NEXT_PUBLIC_SEARCH_MAX_RESULTS=5

# ── Bot protection (Phase 2 — flood report / signup forms) ──────────────
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
